# Identity (name + email) is NOT stored here — kept in ~/.gitconfig.local
# which is written by bootstrap.sh and never committed.
[include]
path = ~/.gitconfig.local

[filter "lfs"]
required = true
clean = git-lfs clean -- %f
smudge = git-lfs smudge -- %f
process = git-lfs filter-process

[core]
editor = vim
autocrlf = input

[pull]
rebase = false

[init]
defaultBranch = main
